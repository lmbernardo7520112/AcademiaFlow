# ============================================================
# AcademiaFlow Appliance — Environment Configuration Template
# ============================================================
#
# VERSION: v1.4.0
# UPDATED: 2026-04-28
#
# USAGE:
#   1. Copy this file to `.env.production`
#   2. Review and customize each section
#   3. Run `docker compose up -d`
#
# IMPORTANT: This file is the TEMPLATE. The actual .env.production
# is NOT committed to version control (it may contain secrets).
# ============================================================

# ─── Application Mode ────────────────────────────────────────
# Valid: 'school_production', 'development'
# school_production: disables self-service registration, hardens access
APP_MODE=school_production
VITE_APP_MODE=school_production

# ─── Database ─────────────────────────────────────────────────
# The compose service 'mongo' resolves to the container name
DATABASE_URL=mongodb://mongo:27017/academiaflow

# ─── JWT Secrets ──────────────────────────────────────────────
# CHANGE THESE in a real deployment — minimum 32 characters
JWT_SECRET=CHANGE_ME_jwt_secret_minimum_32_characters
REFRESH_TOKEN_SECRET=CHANGE_ME_refresh_secret_minimum_32_chars

# ─── Node ─────────────────────────────────────────────────────
NODE_ENV=production

# ─── API ──────────────────────────────────────────────────────
API_PORT=3000

# ─── AI Features (Optional) ──────────────────────────────────
# AI features degrade gracefully (HTTP 503) without this key.
# To enable: uncomment and set a valid Gemini API key.
# GEMINI_API_KEY=your_real_gemini_api_key_here

# ─── SIAGE Interoperability ──────────────────────────────────
# Redis for BullMQ job queue
REDIS_URL=redis://academiaflow_redis:6379

# Encryption keys for SIAGE credential envelope
SIAGE_ENVELOPE_KEY=CHANGE_ME_random_32_hex_chars
SIAGE_WORKER_SECRET=CHANGE_ME_random_32_hex_chars

# ─── SIAGE Pilot Scope Policy ────────────────────────────────
#
# Controls which bimesters the SIAGE module can operate on.
# This is an OPERATIONAL RESTRICTION, not a product limitation.
# The product natively supports bimesters 1-4.
#
# Values:
#   '1'         → current pilot (only 1st bimester)
#   '1,2'       → expanded pilot (1st and 2nd bimester)
#   '1,2,3,4'   → full capability (all bimesters)
#   ''           → full capability (all bimesters)
#
# PROMOTION PROCEDURE:
#   1. Obtain written authorization from the project operator
#   2. Update this value (e.g., '1' → '1,2')
#   3. Restart the API container: docker compose restart api
#   4. Verify via GET /api/siage/pilot-policy
#   5. Document the change in the operational log
#
# DEFAULT: '1' (safe — current pilot scope)
SIAGE_PILOT_BIMESTERS=1

# ─── SIAGE Credential Mode ──────────────────────────────────
#
# Controls whether credential-based SIAGE sync (Playwright scraping) is allowed.
# When 'disabled', POST /siage/runs with credentials returns 403.
# The primary import method is PDF Official Import (Alternativa A).
#
# Values:
#   'disabled' → credential fields hidden, only PDF import allowed (default)
#   'enabled'  → credential-based sync allowed (requires formal authorization)
#
# DEFAULT: 'disabled' (safe — pending formal authorization)
SIAGE_CREDENTIAL_MODE=disabled
